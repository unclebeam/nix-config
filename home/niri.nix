# home/niri.nix — the USER half of niri: glue for the plain KDL config,
# plus swaylock and swayidle. (Session/portal plumbing is system-side in
# modules/niri.nix.) Runs SIDE-BY-SIDE with home/hyprland.nix while niri
# is on trial.
#
# The window-manager config itself is NOT here: it's the plain, tracked
# KDL file home/niri/config.kdl — symlinked, not Nix-generated, same rule
# as helix and hyprland.lua ("editor configs stay plain files"). This file
# only wires it up and exports the few values that must come from Nix.
{
  config,
  lib,
  pkgs,
  ...
}:

let
  colors = import ./colors.nix;
  # swaylock wants rrggbb without the leading '#'; KDL wants it WITH.
  raw = c: lib.removePrefix "#" c;

  # Cursor theme/size come from home/cursor.nix (home.pointerCursor) — the
  # generated nix.kdl below feeds them to niri's cursor section, kept in
  # sync automatically by reading the option.
  cursor = config.home.pointerCursor;

  # The home-manager swayidle unit's PATH contains only bash — every
  # command below must be an absolute store path or it silently fails.
  loginctl = "${pkgs.systemd}/bin/loginctl";
  niri = "${pkgs.niri}/bin/niri"; # same drv programs.niri installs
  swaylock = "${config.programs.swaylock.package}/bin/swaylock";
  pidof = "${pkgs.procps}/bin/pidof";
in
{
  # niri reads ~/.config/niri/config.kdl. NB: no reload hook needed —
  # niri watches the config (and every include) and live-reloads when the
  # store symlink flips after a rebuild.
  xdg.configFile."niri/config.kdl".source = ./niri/config.kdl;

  # Values config.kdl pulls in via its `include`: every color-bearing
  # section (home/colors.nix stays the single source of truth — never
  # hardcode a hex color in the KDL file) plus the cursor theme/size.
  # Include merging is property-level, so only the color properties live
  # here; each section's structure (focus-ring width, gaps…) stays in
  # config.kdl. Data only; all logic stays in config.kdl.
  xdg.configFile."niri/nix.kdl".text = ''
    // Generated by Nix (home/niri.nix). Do not edit — edit
    // home/colors.nix (palette) or home/cursor.nix (cursor) instead.
    layout {
        // Solid melange background, no wallpaper manager.
        background-color "${colors.a.bg}"
        // niri's stock focus indicator is the RING (config.kdl keeps it
        // on, stock width); focused = warm comment-beige, everything
        // else fades into the bg.
        focus-ring {
            active-color "${colors.a.com}"
            inactive-color "${colors.a.float}"
            urgent-color "${colors.b.red}"
        }
        // Tabbed columns (Mod+W), stock structure — colors only.
        tab-indicator {
            active-color "${colors.a.com}"
            inactive-color "${colors.a.float}"
            urgent-color "${colors.b.red}"
        }
        // Drop-target highlight while dragging a window; 80 = ~50% alpha.
        insert-hint {
            color "${colors.a.com}80"
        }
    }
    overview {
        backdrop-color "${colors.a.float}"
    }
    cursor {
        xcursor-theme "${cursor.name}"
        xcursor-size ${toString cursor.size}
    }
  '';

  # ── niri-session.target — the session anchor ────────────────────────────
  # Mirror of hyprland-session.target (home/hyprland.nix): started
  # explicitly by config.kdl's spawn-at-startup, stopped via BindsTo when
  # graphical-session.target goes down at logout. Deliberately NO Install
  # section — the target must only ever be reached by that explicit start,
  # never pulled in whenever a graphical session appears. That scoping is
  # what keeps swayidle (below) out of hyprland sessions, where hypridle
  # already owns idle/lock.
  systemd.user.targets.niri-session = {
    Unit = {
      Description = "niri compositor session";
      Documentation = [ "man:systemd.special(7)" ];
      BindsTo = [ "graphical-session.target" ];
      Wants = [ "graphical-session-pre.target" ];
      After = [ "graphical-session-pre.target" ];
    };
  };

  # ── swaylock — themed lock screen ────────────────────────────────────────
  # What niri's own example setup uses (hyprlock stays untouched for the
  # hyprland session). PAM comes from programs.niri system-side. swaylock's
  # whole UI is the ring indicator: melange ring states stand in for
  # hyprlock's colored input field (verify = green, wrong = red, capslock =
  # yellow), and show-failed-attempts is its counterpart to hyprlock's
  # "$FAIL ($ATTEMPTS)" counter.
  programs.swaylock = {
    enable = true;
    settings = {
      ignore-empty-password = true;
      show-failed-attempts = true;
      indicator-caps-lock = true;

      color = raw colors.a.bg;

      inside-color = raw colors.a.float;
      ring-color = raw colors.a.ui;
      text-color = raw colors.a.fg;
      key-hl-color = raw colors.b.green; # keypress blip
      bs-hl-color = raw colors.b.red; # backspace blip

      inside-ver-color = raw colors.a.float;
      ring-ver-color = raw colors.b.green;
      text-ver-color = raw colors.a.fg;

      inside-wrong-color = raw colors.a.float;
      ring-wrong-color = raw colors.b.red;
      text-wrong-color = raw colors.a.fg;

      inside-caps-lock-color = raw colors.a.float;
      ring-caps-lock-color = raw colors.b.yellow;
      caps-lock-key-hl-color = raw colors.b.yellow;
      caps-lock-bs-hl-color = raw colors.b.red;

      # The thin separator ring adds nothing at this size — blend it away.
      line-color = raw colors.a.bg;
      line-ver-color = raw colors.a.bg;
      line-wrong-color = raw colors.a.bg;
      line-caps-lock-color = raw colors.a.bg;
    };
  };

  # ── swayidle — lock, screen off, and lock-before-sleep ──────────────────
  # Same timeline hypridle runs under hyprland: 5 min → lock, 10 min →
  # screens off (back on when you touch anything), lock BEFORE suspend.
  services.swayidle = {
    enable = true;
    # Scope to the niri session only (see niri-session.target above) —
    # under hyprland, hypridle owns this job and two idle daemons would
    # double-lock.
    systemdTargets = [ "niri-session.target" ];
    timeouts = [
      # 5 min idle → lock
      {
        timeout = 300;
        command = "${loginctl} lock-session";
      }
      # 10 min idle → screens off (niri's DPMS)
      {
        timeout = 600;
        command = "${niri} msg action power-off-monitors";
        resumeCommand = "${niri} msg action power-on-monitors";
      }
    ];
    events = {
      # pidof-guard: loginctl lock-session, the Mod+Escape bind, and
      # before-sleep can all fire this — never stack swaylock instances.
      lock = "${pidof} swaylock || ${swaylock} -f";
      # Lock BEFORE the system suspends (lid close, systemctl suspend…).
      before-sleep = "${loginctl} lock-session";
      # Screens back on when waking from suspend (DPMS state can stick).
      after-resume = "${niri} msg action power-on-monitors";
    };
  };

  # Utilities the config.kdl keybinds shell out to. brightnessctl is ALSO
  # declared in home/hyprland.nix and playerctl in home/waybar.nix — the
  # duplication is deliberate (nix dedupes installs) so that deleting any
  # of those files later stays atomic without orphaning this file's
  # keybind deps. grim/slurp are gone from here on purpose: the stock
  # config uses niri's built-in screenshot UI, the grim→satty pipeline is
  # hyprland-only now.
  home.packages = with pkgs; [
    brightnessctl # backlight (keybinds above; PC just has no backlight device)
    playerctl # stock XF86AudioPlay/Stop/Prev/Next binds
  ];
}
