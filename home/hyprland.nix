# home/hyprland.nix — the USER half of hyprland: glue for the plain lua
# config, plus hyprlock and hypridle. (Session/portal plumbing is system-side
# in modules/hyprland.nix.)
#
# The window-manager config itself is NOT here: it's the plain, tracked lua
# file home/hypr/hyprland.lua — symlinked, not Nix-generated, same rule as
# helix ("editor configs stay plain files"). This file only wires it up and
# exports the few values that must come from Nix.
{
  config,
  lib,
  pkgs,
  ...
}:

let
  colors = import ./colors.nix;
  # hypr color formats want rrggbb without the leading '#'
  raw = c: lib.removePrefix "#" c;

  # Cursor theme/size come from home/cursor.nix (home.pointerCursor) — the
  # lua config sets XCURSOR_THEME/XCURSOR_SIZE from these via nix.lua below,
  # kept in sync automatically by reading the option.
  cursor = config.home.pointerCursor;
in
{
  # Hyprland 0.55 loads ~/.config/hypr/hyprland.lua INSTEAD of hyprland.conf
  # when it exists (hyprlang is deprecated). The home-manager
  # wayland.windowManager.hyprland module is deliberately NOT used: all it
  # would add over this symlink is the systemd session hook, which the lua
  # file carries by hand (see its ⚠ Load-bearing comment). The hyprland
  # package itself comes from the system module (programs.hyprland), so the
  # cap_sys_nice "Hyprland" wrapper stays in charge of the session.
  # NB: no activation hook either — after a rebuild inside a running
  # hyprland session, run `hyprctl reload` yourself.
  xdg.configFile."hypr/hyprland.lua".source = ./hypr/hyprland.lua;

  # Values the lua config reads via require("nix"): the melange palette
  # (home/colors.nix stays the single source of truth — never hardcode a hex
  # color in the lua file) and the cursor theme/size. Data only; all logic
  # stays in hyprland.lua where the lua LSP can see it.
  xdg.configFile."hypr/nix.lua".text = ''
    -- Generated by Nix (home/hyprland.nix). Do not edit — edit
    -- home/colors.nix (palette) or home/cursor.nix (cursor) instead.
    return ${
      lib.generators.toLua { } {
        colors = lib.mapAttrs (_: group: lib.mapAttrs (_: raw) group) colors;
        cursor = {
          inherit (cursor) name size;
        };
      }
    }
  '';

  # Hyprland ships official LuaLS annotation stubs for the whole hl.* API.
  # Symlinking them to a version-stable path lets .luarc.json (repo root —
  # it exists purely because of home/hypr/hyprland.lua) point
  # lua-language-server at them without chasing store paths across
  # hyprland bumps: that's what gives helix completion/hover/type checks
  # inside the lua config.
  xdg.configFile."hypr/stubs".source = "${pkgs.hyprland}/share/hypr/stubs";

  # ── hyprlock — themed lock screen (this session's swaylock) ─────────────
  # PAM side is system-level (modules/hyprland.nix). Color mapping mirrors
  # programs.swaylock in home/sway.nix. hyprlock/hypridle configs stay
  # Nix-generated on purpose (unlike hyprland.lua): they're hyprlang INI
  # with interpolated palette colors and are never iterated on.
  programs.hyprlock = {
    enable = true;
    settings = {
      general.hide_cursor = true;
      animations.enabled = false; # matches the no-animations aesthetic

      background = [
        {
          monitor = "";
          color = "rgb(${raw colors.a.bg})";
        }
      ];

      input-field = [
        {
          monitor = "";
          size = "300, 60";
          outline_thickness = 2;
          rounding = 0;
          inner_color = "rgb(${raw colors.a.float})";
          outer_color = "rgb(${raw colors.a.ui})";
          font_color = "rgb(${raw colors.a.fg})";
          check_color = "rgb(${raw colors.b.green})";
          fail_color = "rgb(${raw colors.b.red})";
          capslock_color = "rgb(${raw colors.b.yellow})";
          # = swaylock's show-failed-attempts
          fail_text = "$FAIL ($ATTEMPTS)";
          placeholder_text = "";
          fade_on_empty = false;
        }
      ];
    };
  };

  # ── hypridle — lock, screen off, and lock-before-sleep ──────────────────
  # Same timeouts as swayidle in home/sway.nix.
  services.hypridle = {
    enable = true;
    # Scope to the hyprland session ONLY. The default target
    # (graphical-session.target) is reached by BOTH sessions, which would
    # start hypridle under sway too, fighting swayidle — the mirror of the
    # systemdTargets override on services.swayidle in home/sway.nix.
    systemdTarget = "hyprland-session.target";
    settings = {
      general = {
        # pidof-guard: loginctl lock-session, the SUPER+Escape bind, and
        # before_sleep can all fire this — never stack hyprlock instances.
        lock_cmd = "pidof hyprlock || hyprlock";
        # Lock BEFORE the system suspends (lid close, systemctl suspend…).
        before_sleep_cmd = "loginctl lock-session";
        # Screens back on when waking from suspend (DPMS state can stick).
        after_sleep_cmd = "hyprctl dispatch 'hl.dsp.dpms({ action = \"enable\" })'";
      };
      listener = [
        # 5 min idle → lock
        {
          timeout = 300;
          on-timeout = "loginctl lock-session";
        }
        # 10 min idle → screens off (back on when you touch anything)
        {
          timeout = 600;
          on-timeout = "hyprctl dispatch 'hl.dsp.dpms({ action = \"disable\" })'";
          on-resume = "hyprctl dispatch 'hl.dsp.dpms({ action = \"enable\" })'";
        }
      ];
    };
  };

  # Wayland desktop utilities used by the lua keybinds. Deliberately the
  # same list as home/sway.nix (nix dedupes): each compositor file must be
  # removable atomically without orphaning the other's keybinds.
  home.packages = with pkgs; [
    grim # screenshot
    slurp # region selection
    wl-clipboard # wl-copy / wl-paste
    brightnessctl # backlight (keybinds above; PC just has no backlight device)
    # LSP for editing home/hypr/hyprland.lua — lives here, not helix.nix, so
    # removing hyprland removes it atomically. Helix picks it up for .lua by
    # default; .luarc.json at the repo root feeds it the hl.* stubs.
    lua-language-server
  ];
}
